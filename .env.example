# ---------------------------------------------------------------------------
# Copy to .env and fill in. Simplest first run: set OPENAI_API_KEY only.
# ---------------------------------------------------------------------------

# Provider keys. One OpenAI key covers chat + embeddings out of the box.
OPENAI_API_KEY=sk-...

# Prefer Claude for chat? Set this, then switch the `chat` alias in
# gateway/litellm_config.yaml to the Anthropic block. No app code changes.
# ANTHROPIC_API_KEY=sk-ant-...

# Gateway master key (the app authenticates to the gateway with this).
LITELLM_MASTER_KEY=sk-sandbox-master

# Model aliases -- resolved by the gateway, not the app. Leave as-is.
CHAT_MODEL=chat
EMBEDDING_MODEL=embeddings
EMBEDDING_DIM=1536

# ---- Observability (optional) ---------------------------------------------
# Unset = tracing disabled, app runs normally. Set the endpoint to ship OTel
# spans to any backend. Example wiring for Langfuse (cloud or self-hosted):
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 of public_key:secret_key>
# Phoenix, Honeycomb, Grafana Tempo work the same way -- just change these two.
OTEL_SERVICE_NAME=ai-stack-sandbox
