# ILLUSTRATIVE additions to .env.example (a spec, not wired in).
# Append these; the existing OPENAI_API_KEY / LITELLM_MASTER_KEY lines stay.

# ---- Failover: same-model redundancy across providers ----------------------
# Direct Anthropic deployment of the chat model (one of the two `chat` entries).
ANTHROPIC_API_KEY=sk-ant-...

# Bedrock deployment of the SAME model (the second `chat` entry + chat-standby).
# Requires an AWS account with per-model Bedrock access enabled for
# anthropic.claude-sonnet-4-6.
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION_NAME=us-east-1

# Pin the eval gate / smoke test at the standby deployment to prove it is a
# viable served model (read by app/config.py -> settings.chat_model). Leave unset
# for normal runs; set only when running the standby eval.
#   CHAT_MODEL=chat-standby
