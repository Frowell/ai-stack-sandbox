# ILLUSTRATIVE — spec for gateway/Dockerfile.
# Extends the stock LiteLLM image so our CustomGuardrail classes and Presidio
# run *inside* the gateway container (design.md §1, Option A). No third-party
# egress, deterministic, offline — so the CI eval-gate gains no paid dependency.

FROM ghcr.io/berriai/litellm:main-stable
# (#07 CI-hardening pins this to a release digest; keep the tag here in sync.)

# Presidio for PII detection/anonymization + a spaCy model for PERSON NER.
# en_core_web_sm (~12MB) keeps the image small; en_core_web_lg (~50MB) is more
# accurate on PERSON — pick per design.md open question.
RUN pip install --no-cache-dir \
        "presidio-analyzer>=2.2" \
        "presidio-anonymizer>=2.2" \
        "spacy>=3.7" \
    && python -m spacy download en_core_web_lg

# guardrails/ is bind-mounted at runtime (see docker-compose) so policy code can
# change without a rebuild; copying it here too keeps the image self-contained
# for environments that don't mount it.
COPY guardrails/ /app/guardrails/
ENV PYTHONPATH=/app

# Cold-start warmup (README fail-mode / AC4). Presidio + the spaCy NER model load
# lazily on first use (seconds), which would blow the 300 ms budget and, under the
# fail-closed default, BLOCK the first real request after every gateway start. The
# entrypoint warms the analyzer (load model + one throwaway analyze/anonymize)
# BEFORE exec'ing litellm, so the server only reports ready post-warmup. The 300 ms
# budget measures steady-state and excludes this one-time load.
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh
ENTRYPOINT ["/app/entrypoint.sh"]
# entrypoint.sh ends with:  exec litellm --config /app/config.yaml --port 4000
# (compose no longer needs its own `command:` once the entrypoint owns the launch).
