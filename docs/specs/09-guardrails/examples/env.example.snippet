# ILLUSTRATIVE — appended to .env.example by this slice.

# ---- Guardrails -----------------------------------------------------------
# Master switch. Default ON. Set to false for a verified no-op (parity test):
# this restores today's behavior exactly, so rollback is one env flip.
GUARDRAILS_ENABLED=true

# DEV-ONLY escape hatch. Default false = fail-CLOSED (a guardrail error/timeout
# BLOCKS the call). Setting true makes guardrails pass through on error and is
# logged loudly on every call. Never set this in a deployment.
GUARDRAIL_FAIL_OPEN=false

# Per-guardrail latency budget (ms). On exceed -> fail-closed (block) by default.
GUARDRAIL_TIMEOUT_MS=300

# Optional hosted detectors (OFF by default; the local Presidio + regex defaults
# need no paid API, keeping CI's eval-gate self-contained and offline).
# LAKERA_API_KEY=
# APORIA_API_KEY=
