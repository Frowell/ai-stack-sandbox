# ILLUSTRATIVE — append to .env.example (which is committed; .env is gitignored).
#
# Discoverability: the var ships COMMENTED so first-run falls back to the master
# key and the stack boots before seeding. `make seed` fills it in (and only fills
# a commented/blank line — it never clobbers a real value).

# Scoped virtual key the app uses for runtime traffic (chat + embeddings).
# Leave commented/blank until you run `make seed`; app/config.py falls back to
# LITELLM_MASTER_KEY when this is unset OR blank.
# LITELLM_VIRTUAL_KEY=

# --- Admin-only (already present): used by `make seed` and admin endpoints, NOT
#     by app runtime traffic once a virtual key is seeded. ---
# LITELLM_MASTER_KEY=sk-sandbox-master

# Optional seed tuning (consumed by scripts/seed_keys.py; sensible defaults exist):
# SEED_MAX_BUDGET=0.01
# SEED_BUDGET_DURATION=30d
# SEED_RPM_LIMIT=3
# SEED_TPM_LIMIT=10000
