# ILLUSTRATIVE — spec for spec 14, not wired-in code.
# Replace/extend the "Observability (optional)" block in .env.example with this.
# Unset OTEL_EXPORTER_OTLP_ENDPOINT => tracing disabled, app runs exactly as today.

# ---- Observability backend ------------------------------------------------
OTEL_SERVICE_NAME=ai-stack-sandbox

# DEFAULT backend = Langfuse (self-hosted via `docker compose --profile observability up`).
# IMPORTANT: `make ask` / `make eval` run on the HOST, so the endpoint must be a
# PUBLISHED localhost port (not the compose service name), and the OTLP-HTTP
# exporter appends /v1/traces, so this must be the collector BASE, not the full
# traces path.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel
# For `docker compose exec app ...` (in-network) runs instead, use the service name:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://langfuse:3000/api/public/otel

# Ingest auth = Basic base64("<public_key>:<secret_key>") of the FIXED dev keys
# below. Recompute if you change the keys:  printf 'pk:sk' | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic cGstbGYtc2FuZGJveDpzay1sZi1zYW5kYm94

# Fixed dev-only bootstrap keys + project id (DEV ONLY — rotate for anything real).
# These let the OTLP endpoint accept traces immediately and make ${PROJECT_ID}
# in the trace_url template knowable without opening the UI.
LANGFUSE_INIT_ORG_ID=sandbox-org
LANGFUSE_INIT_PROJECT_ID=sandbox-project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-sandbox
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-sandbox

# result -> trace link. ${VARS} expand from env; {trace_id} filled per case.
# Unset => trace_url stored NULL (row still carries a usable trace_id).
LANGFUSE_HOST=http://localhost:3000
PROJECT_ID=sandbox-project
OTEL_TRACE_URL_TEMPLATE=${LANGFUSE_HOST}/project/${PROJECT_ID}/traces/{trace_id}

# trace -> result link (optional, Langfuse-only). 'langfuse' lazily imports the
# Langfuse SDK; default 'noop' imports no vendor SDK.
EVAL_SCORE_SINK=langfuse
# The LangfuseSink SDK reads these (same fixed dev keys):
LANGFUSE_PUBLIC_KEY=pk-lf-sandbox
LANGFUSE_SECRET_KEY=sk-lf-sandbox

# PII posture: capture content-bearing span attributes (input.question,
# retrieval.query). Default on for the sandbox; set 0 in any env with real data.
OTEL_CAPTURE_CONTENT=1

# ---- ALTERNATIVE backend = Phoenix (single container, OTLP-only, no scores) ---
# Bring it up with `docker compose --profile observability-phoenix up`, then use:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACE_URL_TEMPLATE=http://localhost:6006/projects/default/traces/{trace_id}  # verify path vs Phoenix version
# EVAL_SCORE_SINK=noop        # Phoenix has no scores API
# (Phoenix needs none of the LANGFUSE_* / OTEL_EXPORTER_OTLP_HEADERS lines.)
